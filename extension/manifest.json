{
  "manifest_version": 3,
  "name": "Alonia Booking Scraper",
  "version": "1.1",
  "description": "Sends booking details to your Alonia server when browsing Airbnb or Booking.com",
  "permissions": ["storage", "scripting", "tabs"],
  "host_permissions": [
    "https://www.airbnb.com/*",
    "https://admin.booking.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.airbnb.com/hosting/reservations*",
        "https://www.airbnb.com/hosting/reservations/details/*"
      ],
      "js": ["scrapers/airbnb.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://admin.booking.com/hotel/hoteladmin/extranet_ng/manage/booking*"
      ],
      "js": ["scrapers/booking.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Alonia Booking Scraper",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
